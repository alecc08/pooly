# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pooly
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pooly

# ── API FastAPI ───────────────────────────────────────────────────────────────
# Doit correspondre aux variables PostgreSQL ci-dessus
DATABASE_URL=postgresql+psycopg://pooly:changeme@db:5432/pooly

# Clé secrète pour les sessions — générer avec : openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-secret

# Compte admin créé automatiquement au démarrage (optionnel)
# Si non défini, aucun compte admin n'est créé automatiquement
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword1

# Origines autorisées pour CORS (séparées par des virgules)
# En prod : mettre uniquement l'URL publique du frontend
ALLOWED_ORIGINS=http://localhost:8090

# URL publique de l'application (utilisée dans les liens de reset password, etc.)
APP_BASE_URL=http://localhost:8090

# Mode debug — affiche les tokens de reset dans les logs (ne jamais activer en prod)
DEBUG=false

# ── Plages de référence (ideal/acceptable) ─────────────────────────────────────
# Surcharge les plages par défaut définies dans WATER_PARAMS (apps/api/main.py),
# par combinaison (type, désinfectant) et par paramètre. Convention :
#   RANGE_<TYPE>_<SANITIZER>_<PARAM>_{IDEAL,ACCEPTABLE}_{MIN,MAX}
#   TYPE      = PISCINE | SPA
#   SANITIZER = BROME | CHLORE | SEL
#   PARAM     = PH | CL | BR | CC | TAC | TEMP | SALT | CYA | DURETE
# Non défini = valeur par défaut inchangée. Chaque bord (MIN/MAX) de chaque
# plage (IDEAL/ACCEPTABLE) peut être surchargé indépendamment.
#
# Exemple : votre chlorolyseur au sel vise 4000 ppm plutôt que la valeur par défaut
# RANGE_PISCINE_SEL_SALT_IDEAL_MIN=3600
# RANGE_PISCINE_SEL_SALT_IDEAL_MAX=4400

# ── Frontend ──────────────────────────────────────────────────────────────────
# Port exposé sur l'hôte pour le frontend
WEB_PORT=8090

# URL de l'API côté Nginx (interne Docker par défaut)
# Changer si l'API tourne en dehors de Docker (ex: API sur un serveur séparé)
# BACKEND_URL=http://192.168.1.178:8003
BACKEND_URL=http://api:8003
