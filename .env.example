# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pooly
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pooly

# ── API FastAPI ───────────────────────────────────────────────────────────────
# Must match the PostgreSQL variables above
DATABASE_URL=postgresql+psycopg://pooly:changeme@db:5432/pooly

# Secret key for sessions — generate with: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-secret

# Admin account created automatically at startup (optional)
# If unset, no admin account is created automatically
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword1

# Allowed origins for CORS (comma-separated)
# In prod: set only the frontend's public URL
ALLOWED_ORIGINS=http://localhost:8090

# Public URL of the application (used in password reset links, etc.)
APP_BASE_URL=http://localhost:8090

# Debug mode — logs reset tokens (never enable in prod)
DEBUG=false

# ── Reference ranges (ideal/acceptable) ────────────────────────────────────────
# Overrides the default ranges defined in WATER_PARAMS (apps/api/main.py),
# per (type, sanitizer) combo and per parameter. Convention:
#   RANGE_<TYPE>_<SANITIZER>_<PARAM>_{IDEAL,ACCEPTABLE}_{MIN,MAX}
#   TYPE      = POOL | SPA
#   SANITIZER = BROMINE | CHLORINE | SALT
#   PARAM     = PH | CL | BR | CC | TAC | TEMP | SALT | CYA | HARDNESS
# Unset = default value unchanged. Each edge (MIN/MAX) of each
# range (IDEAL/ACCEPTABLE) can be overridden independently.
#
# Example: your salt chlorinator targets 4000 ppm instead of the default
# RANGE_POOL_SALT_SALT_IDEAL_MIN=3600
# RANGE_POOL_SALT_SALT_IDEAL_MAX=4400

# ── Frontend ──────────────────────────────────────────────────────────────────
# Port exposed on the host for the frontend
WEB_PORT=8090

# API URL on the Nginx side (internal Docker by default)
# Change if the API runs outside Docker (e.g. API on a separate server)
# BACKEND_URL=http://192.168.1.178:8003
BACKEND_URL=http://api:8003
