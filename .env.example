# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=homepool
POSTGRES_PASSWORD=changeme
POSTGRES_DB=homepool

# ── API FastAPI ───────────────────────────────────────────────────────────────
# Must match the PostgreSQL variables above
DATABASE_URL=postgresql+psycopg://homepool:changeme@db:5432/homepool

# Secret key for sessions — generate with: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-secret

# Admin account created automatically at startup (optional)
# If unset, no admin account is created automatically
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword1

# Allowed origins for CORS (comma-separated)
# In prod: set only the frontend's public URL
ALLOWED_ORIGINS=http://localhost:8090

# Public URL of the application (used in password reset links, etc.)
APP_BASE_URL=http://localhost:8090

# Debug mode — logs reset tokens (never enable in prod)
DEBUG=false

# NOTE: Reference ranges (ideal/acceptable) are no longer configurable via
# RANGE_<TYPE>_<SANITIZER>_<PARAM>_{IDEAL,ACCEPTABLE}_{MIN,MAX} env vars — that
# mechanism was removed in favor of per-installation, UI-editable ranges (see the
# installation's "Water Chemistry Targets" tab). If you were relying on RANGE_*
# env vars, re-apply your preferred ranges per-installation via the UI after
# upgrading; unset RANGE_* vars are now ignored.

# ── Frontend ──────────────────────────────────────────────────────────────────
# Port exposed on the host for the frontend
WEB_PORT=8090

# API URL on the Nginx side (internal Docker by default)
# Change if the API runs outside Docker (e.g. API on a separate server)
# BACKEND_URL=http://192.168.1.178:8003
BACKEND_URL=http://api:8003
